# CKafka Broker 地址（必填），多个用逗号分隔
KAFKA_BROKERS=172.21.x.x:9092

# Topic 名称
KAFKA_TOPIC=ags-monitor

# Consumer Group ID
KAFKA_GROUP=ags-prometheus-exporter

# SASL 认证（生产环境建议开启）
KAFKA_SASL_ENABLE=false
KAFKA_SASL_USER=
KAFKA_SASL_PASSWORD=

# TLS（公网接入时开启）
KAFKA_TLS_ENABLE=false

# 首次接入建议 true，避免回放历史数据
KAFKA_OFFSET_NEWEST=true

# 沙箱停止后指标保留秒数
METRIC_TTL_SECONDS=300
