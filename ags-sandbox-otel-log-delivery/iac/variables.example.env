# Copy this file to .env.local and fill it with customer environment values.
# Do not commit .env.local, SecretId, SecretKey, temporary tokens, or internal RoleArn values.

AGS_TOOL_NAME=ags-log-delivery-example
AGS_IMAGE="ccr.ccs.tencentyun.com/<namespace>/<repo>:<tag>"
AGS_IMAGE_REGISTRY_TYPE=personal
# Fill this only when the image registry or storage mounts require cloud access.
AGS_ROLE_ARN=

AGS_SUBNET_ID=subnet-xxxx
AGS_SECURITY_GROUP_ID=sg-xxxx

OTLP_ENDPOINT="<collector-private-host>:4317"
# Use true only for private validation endpoints without TLS. For production,
# configure TLS according to the customer's collector and set this accordingly.
OTEL_EXPORTER_OTLP_INSECURE=true
LOG_FILE_PATTERNS="/app/logs/*.log,/tmp/customer-logs/*.log,/data/customer/logs/**/*.log"
LOG_EXCLUDE_FILE_PATTERNS="/var/log/ags-collector/*.log"
LOG_RESOURCE_ENV_KEYS="APP_ENV,CUSTOMER_ID,BUILD_ID,REGION"

# These values are the business attributes that will be exported because they
# are listed in LOG_RESOURCE_ENV_KEYS. Keep this list explicit; do not export
# all environment variables from the sandbox.
APP_ENV=prod
CUSTOMER_ID=example-customer
BUILD_ID=build-001
# This REGION is an application attribute exported to logs. It is separate
# from TENCENTCLOUD_REGION, which controls which AGS API region the scripts call.
REGION=ap-guangzhou
LOG_START_AT=beginning
SANDBOX_ID_PIPE="/run/ags/sandbox-id.pipe"
SANDBOX_ID_WAIT_TIMEOUT=0
ENVD_COMMAND=/usr/bin/envd
ENVD_ARGS="-port 49983"
ENVD_PORT=49983
PROBE_PATH=/health
PROBE_PORT=49983
PROBE_READY_TIMEOUT_MS=30000
PROBE_TIMEOUT_MS=1000
PROBE_PERIOD_MS=3000
PROBE_FAILURE_THRESHOLD=10
EXTRA_ENV_JSON='[
  {"Name":"APP_ENV","Value":"prod"},
  {"Name":"CUSTOMER_ID","Value":"example-customer"},
  {"Name":"BUILD_ID","Value":"build-001"},
  {"Name":"REGION","Value":"ap-guangzhou"}
]'

SERVICE_NAME="<customer-service-name>"
APP_PORT=8080
BUSINESS_COMMAND="uv run uvicorn app.server:app --host 0.0.0.0 --port 8080"

AGS_RESOURCE_CPU=2
AGS_RESOURCE_MEMORY=4Gi

PURPOSE_TAG=ags-log-delivery
PROJECT_TAG=
OWNER_TAG=
BILLING_TAG_VALUE=
